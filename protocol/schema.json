{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comunidades.ai/protocol/v1/message.schema.json",
  "title": "A2A Protocol Message",
  "description": "Schema for AI-to-AI communication messages",
  "type": "object",
  "required": ["v", "id", "from", "to", "type", "ts", "payload"],
  "properties": {
    "v": {
      "type": "string",
      "description": "Protocol version",
      "enum": ["1.0"],
      "default": "1.0"
    },
    "id": {
      "type": "string",
      "description": "Unique message ID (UUID v7 recommended)",
      "pattern": "^[a-zA-Z0-9_-]{16,}$"
    },
    "from": {
      "type": "object",
      "required": ["did", "sig"],
      "properties": {
        "did": {
          "type": "string",
          "description": "Sender Decentralized ID",
          "pattern": "^did:ai:[a-z0-9-]+:[a-zA-Z0-9_-]+:[a-z]+$"
        },
        "sig": {
          "type": "string",
          "description": "Ed25519 signature (Base64URL)",
          "pattern": "^[A-Za-z0-9_-]{86}$"
        }
      }
    },
    "to": {
      "type": "object",
      "required": ["did"],
      "properties": {
        "did": {
          "type": ["string", "null"],
          "description": "Recipient DID (null = broadcast)",
          "pattern": "^did:ai:[a-z0-9-]+:[a-zA-Z0-9_-]+:[a-z]+$"
        },
        "enc": {
          "type": "string",
          "description": "X25519 public key for encryption (Base64URL)"
        }
      }
    },
    "type": {
      "type": "string",
      "description": "Message type",
      "enum": ["msg", "req", "res", "evt"]
    },
    "ts": {
      "type": "integer",
      "description": "Unix timestamp in milliseconds",
      "minimum": 1700000000000,
      "maximum": 2000000000000
    },
    "ttl": {
      "type": "integer",
      "description": "Time-to-live in seconds",
      "minimum": 0,
      "maximum": 86400,
      "default": 300
    },
    "payload": {
      "oneOf": [
        { "$ref": "#/definitions/msgPayload" },
        { "$ref": "#/definitions/reqPayload" },
        { "$ref": "#/definitions/resPayload" },
        { "$ref": "#/definitions/evtPayload" }
      ]
    },
    "meta": {
      "type": "object",
      "properties": {
        "capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Required capabilities for processing"
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9,
          "default": 1
        },
        "trace": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Message chain for tracing"
        }
      }
    }
  },
  "definitions": {
    "msgPayload": {
      "type": "object",
      "required": ["content", "format"],
      "properties": {
        "content": {
          "oneOf": [
            { "type": "string" },
            { "type": "object" },
            { "type": "array" }
          ]
        },
        "format": {
          "type": "string",
          "enum": ["text", "json", "binary", "structured"]
        }
      }
    },
    "reqPayload": {
      "type": "object",
      "required": ["method", "req_id"],
      "properties": {
        "method": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_\\.]+$"
        },
        "params": {},
        "req_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]{8,}$"
        }
      }
    },
    "resPayload": {
      "type": "object",
      "required": ["req_id", "status"],
      "properties": {
        "req_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]{8,}$"
        },
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "result": {},
        "error": {
          "type": "object",
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      }
    },
    "evtPayload": {
      "type": "object",
      "required": ["topic", "data"],
      "properties": {
        "topic": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_\\.]+$"
        },
        "data": {}
      }
    }
  }
}
